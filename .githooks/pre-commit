#!/usr/bin/env sh

# Only run the full test suite when actual code/config/test files are staged.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
CODE_FILES=$(echo "$STAGED" | grep -E '\.(ts|tsx|mjs|css|json)$|^build\.ts$|^server\.ts$')

if [ -z "$CODE_FILES" ]; then
  echo "pre-commit: no code files staged — skipping test:local"
  exit 0
fi

if command -v corepack >/dev/null 2>&1; then
  corepack pnpm test:local
elif command -v pnpm >/dev/null 2>&1; then
  pnpm test:local
else
  echo "pre-commit: pnpm not found and corepack is unavailable" >&2
  exit 1
fi