#!/usr/bin/env sh

# Only run the full test suite when actual code/config/test files are staged.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
CODE_FILES=$(echo "$STAGED" | grep -vE '^(\.agents)/' | grep -E '\.(ts|tsx|mjs|css|json)$|^build\.ts$|^server\.ts$')

if [ -z "$CODE_FILES" ]; then
  echo "pre-commit: no code files staged — skipping test:local"
  exit 0
fi

# Resolve bun via common locations
PATH="$HOME/.bun/bin:$PATH:/c/Users/jared/.bun/bin"
if command -v bun >/dev/null 2>&1; then
  bun test:local
else
  echo "pre-commit: bun not found — skipping test:local"
  exit 0
fi