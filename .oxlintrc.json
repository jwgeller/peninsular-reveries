{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "jsx-a11y"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "pedantic": "warn"
  },
  "rules": {
    "no-empty-file": "off",
    "no-new-array": "off"
  },
  "env": {
    "builtin": true,
    "browser": true
  }
}