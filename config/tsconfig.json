{
  "compilerOptions": {
    "target": "ES2025",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@remix-run/ui",
    "lib": ["ES2025", "DOM"],
    "types": ["node"]
  },
  "include": [
    "../app/**/*.ts",
    "../app/**/*.tsx",
    "../client/**/*.ts",
    "../client/**/*.tsx",
    "../games/**/*.ts",
    "../games/**/*.tsx",
    "../e2e/**/*.ts",
    "./**/*.ts",
    "../build.ts",
    "../server.ts"
  ]
}