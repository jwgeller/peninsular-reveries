{
  "name": "peninsular-reveries",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "scripts": {
    "build": "tsx --tsconfig config/tsconfig.json build.ts",
    "check": "pnpm lint && pnpm typecheck",
    "lint": "eslint --config config/eslint.config.mjs .",
    "generate:pixel-art": "tsx --tsconfig config/tsconfig.json scripts/generate-pixel-art.ts",
    "sync:attributions": "tsx --tsconfig config/tsconfig.json scripts/sync-attributions.ts",
    "typecheck": "tsc --noEmit -p config/tsconfig.json",
    "dev": "tsx --tsconfig config/tsconfig.json server.ts",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:local": "pnpm check && pnpm test",
    "test:unit": "node --import tsx --test app/**/*.test.ts client/**/*.test.ts config/**/*.test.ts games/**/*.test.ts",
    "test:e2e": "pnpm exec playwright test --config config/playwright.config.ts --reporter=list",
    "test:report": "pnpm test:unit && pnpm exec playwright test --config config/playwright.config.ts",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@types/node": "24.12.2",
    "esbuild": "0.28.0",
    "eslint": "10.2.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "globals": "17.4.0",
    "serve": "14.2.6",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "@remix-run/component": "0.6.0",
    "@remix-run/fetch-router": "0.18.0",
    "@remix-run/node-fetch-server": "0.13.0"
  }
}
