{
  "name": "peninsular-reveries",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "check": "bun run lint && bun run typecheck",
    "lint": "oxlint --ignore-path .oxlintignore",
    "generate:pixel-art": "bun run scripts/generate-pixel-art.ts",
    "sync:attributions": "bun run scripts/sync-attributions.ts",
    "typecheck": "tsgo --noEmit -p config/tsconfig.json",
    "dev": "bun run server.ts",
    "start": "bun run server.ts --production",
    "test": "bun test",
    "test:local": "bun run check && bun test",
    "test:unit": "bun test",
    "test:e2e": "npx playwright test --config config/playwright.config.ts --reporter=list",
    "test:report": "bun test && npx playwright test --config config/playwright.config.ts",
    "prepare": "bun scripts/install-git-hooks.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@remix-run/fetch-router": "0.18.2",
    "@remix-run/node-fetch-server": "0.13.1",
    "@remix-run/ui": "0.1.1",
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260515.1",
    "esbuild": "0.28.0",
    "oxlint": "1.63.0",
    "pixi.js": "8.18.1"
  },
  "packageManager": "bun@1.3.13"
}