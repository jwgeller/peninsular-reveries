{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "remix/component",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "client/**/*.ts",
    "client/**/*.tsx",
    "tests/**/*.ts",
    "tests-node/**/*.ts",
    "build.ts",
    "server.ts",
    "playwright.config.ts"
  ]
}
